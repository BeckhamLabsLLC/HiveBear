{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "HiveBear default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://hivebear.com/*" },
        { "url": "https://github.com/BeckhamLabsLLC/*" }
      ]
    }
  ]
}
